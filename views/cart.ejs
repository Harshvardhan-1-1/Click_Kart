<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
     <link rel="stylesheet" href="/stylesheets/style.css">

      <link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="h-screen">
    <div class="h-25 w-full p-5 flex justify-between ">
         <a href="/shop" class="text-3xl font-bold text-violet-700">ClickKart</a>
         <div class="flex gap-20 text-xl">
            <a href="/shop">Shop</a>
            <a href="/cart">Cart</a>
            <a href="/contactus">Contact Us</a>
            <a href="/users/logout" class="text-red-500">Logout</a>
         </div>
    </div>

    <div class="h-[calc(100vh-100px)] w-full flex gap-10 p-5">
        <div class="h-full w-1/3 flex flex-col gap-5">
            <% user.cart.forEach((cart)=>{ %>

                <div class="h-3/5 bg-[user.cart[0].bgcolor] flex justify-center items-center w-full">

                <img class="h-full  object-cover  " src="data:image/jpeg;base64,<%= cart.image.toString('base64') %>" alt="" >

            </div>


            <div class="flex flex-col gap-5">
                <div class="w-full text-2xl flex justify-between">
                    <h1 class=""><%= cart.name %></h1>
                    <div class="flex gap-5">
                        <a href="">+</a>
                        <h1>01</h1>
                        <a href="/remove/<%= cart._id %>">-</a>
                    </div>
                </div>

                <div class="text-xl py-2 flex justify-between">
                    <h1>Net Total</h1>
                    <h1>₹<%= cart.price - cart.discount %></h1>
                </div>

            </div>
            <% }) %>
        </div>



       

            


            

             <div class=" w-2/3 sticky top-5 h-fit">

                <% let sum = 0; %>
                <% let dis = 0 %>
                <% user.cart.forEach((cart)=>{  %>    
                    <% sum += cart.price %>
                    <% dis += cart.discount %>
                <% }) %>


                <h1 class="text-3xl">Price Breakdown</h1>
            <div class="w-1/2 h-50 p-5 text-xl mt-5 ml-10 flex flex-col gap-3 mb-20">
                <div class="flex justify-between">
                    <h1>Total MRP</h1>
                    <h1>₹<%= sum %></h1>
                </div>
                <div class="flex justify-between">
                    <h1>Discount On MRP</h1>
                    <h1>₹<%= dis %></h1>
                </div>
                <div class="flex justify-between">
                    <h1>Platform Fee</h1>
                    <h1>₹0</h1>
                </div>
                <div class="flex justify-between">
                    <h1>Shipping Fee</h1>
                    <h1>₹0</h1>
                </div>
            </div>
            <hr class="border border-2 mb-10">
            <div class="flex justify-between text-2xl w-130">
                <h1>Total Breakdown</h1>
                <h1 class="text-green-500">₹<%= sum-dis %></h1>
            </div>



            
        </div>

            
        
    </div>
</body>
</html>