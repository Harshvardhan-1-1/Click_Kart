<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
     <link rel="stylesheet" href="/stylesheets/style.css">

      <link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen ">

       <% if( error.length > 0){ %>
    <div id="message" class="fixed top-5 right-5 bg-red-500 text-white px-4 py-2 rounded">
        <%= error[0] %>
    </div>
<% } %>


    <div class="container flex h-screen w-full">
           <a href="/shop" class="absolute top-5 left-5 text-3xl font-bold text-violet-700">ClickKart</a>
        <div class="left p-5 flex justify-center items-center h-full w-2/3 ">
           
          <div class="flex flex-col w-3/5">
            <h1 class="text-5xl px-5 text-violet-700 font-bold">Log in</h1>
            <form action="/users/login" method="post">
                <div class="flex flex-col mt-20 items-center p-5">
                <div class="w-full">
                    <h4 class="">E-mail</h4>
                <input class="p-3 w-full bg-gray-300 rounded-3xl outline-violet-700 mb-5" type="email" placeholder="E-mail" name="email">
                </div>
                <div class="w-full">
                    <h4 class="">Password</h4>
                <input class="p-3 w-full bg-gray-300 rounded-3xl outline-violet-700 mb-5" type="password" placeholder="Password" name="password">
                </div>
                <input type="submit" name="submit" value="Log in Account" class="bg-violet-700 p-3 text-white w-full rounded-3xl">
            </div>
            <a href="/" class="px-5 text-violet-700 font-bold">Or Sign up</a>
          </div>
            </form>
          
        </div>
        <div class="right p-5 h-full w-1/3 bg-violet-700"></div>
    </div>

    <script>
        setTimeout(()=>{
            const message = document.getElementById("message")
            if(message){
                message.remove()
            }
        },3000)
        </script>


</body>
</html>